# ─────────────────────────────────────────────────────────────────────────────
# AdaptIQ — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB connection string (local)
MONGO_URI=mongodb://localhost:27017

# MongoDB database name
DB_NAME=adaptive_engine

# Google Gemini API key
# Get yours FREE at https://aistudio.google.com → API Keys → Create API Key
# No credit card required!
GEMINI_API_KEY=AIzaSyBmu0pkCjHOFgGWJFZJAZNSZ9oyLKV0F8Y

# Number of questions per test session
MAX_QUESTIONS=10

# Initial ability score (0 to 1 scale)
INITIAL_ABILITY=0.5
